# Cesium Ion (https://ion.cesium.com/tokens) — 可选；留空或占位符时使用 Esri 底图
# VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# API
API_HOST=0.0.0.0
API_PORT=8000
DATA_DIR=./data
PROCESSED_DIR=./data/processed
RAW_DIR=./data/raw

# GFS via Herbie
GFS_MODEL=gfs
GFS_PRODUCT=0p25
GFS_FORECAST_HOURS=0,6,12

# Copernicus Marine (https://data.marine.copernicus.eu/)
CMEMS_USERNAME=
CMEMS_PASSWORD=
CMEMS_DATASET_ID=cmems_mod_glo_phy-cur_anfc_0.083deg_PT6H-i

# Enable background GFS ingest every 6h (default off for local dev)
ENABLE_SCHEDULER=false

# Point weather cache (Open-Meteo / wttr.in HUD)
POINT_WEATHER_CACHE_TTL_SEC=900
POINT_MULTI_CACHE_TTL_SEC=900
POINT_PROVIDER_TIMEOUT_SEC=12
ENABLE_WEB_WEATHER=true

# Optional: OpenWeatherMap for /weather/point/multi (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Frontend API base
VITE_API_BASE_URL=http://localhost:8000
